{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "clinicaokazaki.com" }],
      "destination": "https://www.clinicaokazaki.com/:path*",
      "permanent": true
    },
    { "source": "/unidades", "destination": "/#unidades", "permanent": true },
    { "source": "/equipe", "destination": "/#equipe", "permanent": true },
    { "source": "/nossa-equipe", "destination": "/#equipe", "permanent": true },
    { "source": "/convenios", "destination": "/#convenios", "permanent": true },
    { "source": "/convênios", "destination": "/#convenios", "permanent": true },
    { "source": "/procedimentos", "destination": "/", "permanent": true },
    { "source": "/exames", "destination": "/", "permanent": true },
    { "source": "/contato", "destination": "/#unidades", "permanent": true },
    { "source": "/contatos", "destination": "/#unidades", "permanent": true },
    { "source": "/sobre", "destination": "/", "permanent": true },
    { "source": "/sobre-nos", "destination": "/", "permanent": true },
    { "source": "/endoscopia-digestiva-alta", "destination": "/endoscopia", "permanent": true },
    { "source": "/endoscopia-alta", "destination": "/endoscopia", "permanent": true },
    { "source": "/preparacao-colonoscopia", "destination": "/preparo-colonoscopia", "permanent": true },
    { "source": "/preparacao-endoscopia", "destination": "/preparo-endoscopia", "permanent": true },
    { "source": "/preparo-para-colonoscopia", "destination": "/preparo-colonoscopia", "permanent": true },
    { "source": "/preparo-para-endoscopia", "destination": "/preparo-endoscopia", "permanent": true },
    { "source": "/gastro", "destination": "/gastroenterologia", "permanent": true },
    { "source": "/gastroenterologista", "destination": "/gastroenterologia", "permanent": true },
    { "source": "/hepato", "destination": "/hepatologia", "permanent": true },
    { "source": "/hepatologista", "destination": "/hepatologia", "permanent": true },
    { "source": "/geriatra", "destination": "/geriatria", "permanent": true },
    { "source": "/home", "destination": "/", "permanent": true },
    { "source": "/index", "destination": "/", "permanent": true }
  ],
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
